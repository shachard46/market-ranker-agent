{"type":"message","id":"c41d7018","parentId":"daf77797","timestamp":"2026-03-20T12:53:10.131Z","message":{"role":"toolResult","toolCallId":"call_00_9snm4TgvNVFhXMfdeyr8T7Iu","toolName":"read","content":[{"type":"text","text":"import sqlite3\nimport subprocess\nimport json\nimport time\nimport os\n\n# Exact path based on your terminal output\nID_FILE = os.path.expanduser(\"~/.openclaw/workspace/relevant_markets/raw_ids.txt\")\nDB_FILE = \"arbitrage_ledger.db\"\nSKILL_DIR = os.path.expanduser(\"~/.openclaw/skills/market-scarper\")\n\ndef pop_first_line(filepath):\n    if not os.path.exists(filepath) or os.path.getsize(filepath) == 0:\n        return None\n    with open(filepath, 'r') as f:\n        lines = f.readlines()\n    if not lines:\n        return None\n    first_line = lines[0].strip()\n    with open(filepath, 'w') as f:\n        f.writelines(lines[1:])\n    return first_line\n\ndef get_market_field(market_id, field):\n    command = [\"python3\", \"-m\", \"polymarket_tools\", \"query_market_field\", market_id, field]\n    try:\n        result = subprocess.run(command, capture_output=True, text=True, check=True, cwd=SKILL_DIR)\n        raw_output = result.stdout.strip()\n        try:\n            return json.loads(raw_output).get(\"value\", raw_output)\n        except json.JSONDecodeError:\n            return raw_output \n    except subprocess.CalledProcessError:\n        return None\n\ndef hydrate_database():\n    print(f\"📥 [0/4] Hydrating SQL Database from {ID_FILE}...\")\n    conn = sqlite3.connect(DB_FILE)\n    cursor = conn.cursor()\n    \n    while True:\n        market_id = pop_first_line(ID_FILE)\n        if not market_id: break\n            \n        question = get_market_field(market_id, \"question\")\n        price_str = get_market_field(market_id, \"last_trade_price\")\n        \n        if question:\n            short_id = f\"BET_{market_id[-5:]}\"\n            try:\n                market_price = float(price_str) * 100 if price_str and price_str != \"None\" else 50.0\n            except ValueError:\n                market_price = 50.0\n            \n            cursor.execute('''\n                INSERT OR IGNORE INTO bets (market_id, short_id, question, market_price, status)\n                VALUES (?, ?, ?, ?, 'pending')\n            ''', (market_id, short_id, question, market_price))\n            \n            print(f\"   ↳ Added {short_id} to SQL: '{question[:45]}...' (Market: {market_price}%)\")\n            \n    conn.commit()\n    conn.close()\n\ndef process_pipeline():\n    conn = sqlite3.connect(DB_FILE)\n    cursor = conn.cursor()\n    \n    cursor.execute(\"SELECT market_id, short_id, question, market_price FROM bets WHERE status = 'pending'\")\n    pending_bets = cursor.fetchall()\n    \n    if not pending_bets:\n        print(\"   💤 No pending bets found in the SQL database.\")\n        return\n\n    for bet in pending_bets:\n        market_id, short_id, question, market_price = bet\n        print(f\"\\n--- Processing SQL Record: {short_id} ---\")\n        \n        print(f\"📐 [1/4] Architect is building the brief...\")\n        cmd_arch = [\"openclaw\", \"agent\", \"--agent\", \"architect\", \"--message\", f\"{question} Do not chat. Output ONLY the RESEARCH_BRIEF using S.P.E.C.\", \"--local\"]\n        res_arch = subprocess.run(cmd_arch, capture_output=True, text=True, timeout=60)\n        brief = res_arch.stdout.strip()\n        \n        # THE FIX: Calling the researcher but forcing it to use the aiq skill\n        print(f\"🧠 [2/4] Researcher is using AI-Q Deep Search skill to gather intel...\")\n        cmd_aiq = [\"openclaw\", \"agent\", \"--agent\", \"researcher\", \"--message\", f\"Use your 'aiq' deep search skill to execute this research brief. Keep the final report under 500 words with hard metrics. BRIEF: {brief}\", \"--local\"]\n        res_aiq = subprocess.run(cmd_aiq, capture_output=True, text=True, timeout=180)\n        report = res_aiq.stdout.strip()\n        \n        print(f\"🧮 [3/4] Predicter calculating true odds...\")\n        cmd_pred = [\"openclaw\", \"agent\", \"--agent\", \"percentage_predicter\", \"--message\", f\"Output final probability in strict JSON based on this report. REPORT: {report}\", \"--local\"]\n        res_pred = subprocess.run(cmd_pred, capture_output=True, text=True, timeout=60)\n        prediction_json = res_pred.stdout.strip()\n        \n        try:\n            ai_percentage = json.loads(prediction_json).get(\"probability_percentage\", 50)\n        except:\n            ai_percentage = 50\n            \n        alpha_gap = abs(ai_percentage - market_price)\n        print(f\"📊 [4/4] Market: {market_price}% | AI: {ai_percentage}% | Alpha Gap: {alpha_gap}%\")\n        \n        if alpha_gap >= 10:\n            print(f\"   🚨 EXPLOITABLE EDGE DETECTED! Gap is >= 10%.\")\n            final_status = 'actionable_trade'\n        else:\n            print(f\"   💤 Gap too small. Passing.\")\n            final_status = 'completed'\n            \n        cursor.execute('''\n            UPDATE bets \n            SET status = ?, research_brief = ?, final_report = ?, ai_prediction_percentage = ?, alpha_gap = ?\n            WHERE market_id = ?\n        ''', (final_status, brief, report, ai_percentage, alpha_gap, market_id))\n        conn.commit()\n        time.sleep(2)\n\n    conn.close()\n\nif __name__ == \"__main__\":\n    print(\"🚀 Starting SQL Arbitrage Engine...\")\n    hydrate_database()\n    process_pipeline()\n    print(\"\\n🎉 Pipeline finished successfully!\")\n"}],"isError":false,"timestamp":1774011190128}}
