{"type":"message","id":"bc4a2f06","parentId":"91ec6027","timestamp":"2026-03-15T23:50:35.070Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create a comprehensive analysis script that compiles all the findings:"},{"type":"toolCall","id":"call_00_hc2sPrI8jX0VgbMRN4nwSOrI","name":"exec","arguments":{"command":"cd ~/.openclaw/skills/market-scarper && source venv/bin/activate && python3 -c \"\nimport sqlite3\nimport pandas as pd\nfrom datetime import datetime\nconn = sqlite3.connect('polymarket.db')\n\n# Get today's date for filename\ntoday = datetime.now().strftime('%Y-%m-%d')\n\n# Strategy 1: Breakouts (>10% price changes)\nbreakouts_query = '''\nWITH recent_changes AS (\n    SELECT \n        market_id,\n        last_trade_price,\n        datetime,\n        ROW_NUMBER() OVER (PARTITION BY market_id ORDER BY datetime DESC) as rn\n    FROM market_change\n    WHERE last_trade_price IS NOT NULL\n    AND datetime >= datetime('now', '-3 days')\n),\nprice_changes AS (\n    SELECT \n        r1.market_id,\n        r1.last_trade_price as current_price,\n        r2.last_trade_price as previous_price,\n        (r1.last_trade_price - r2.last_trade_price) / NULLIF(r2.last_trade_price, 0) as pct_change\n    FROM recent_changes r1\n    JOIN recent_changes r2 ON r1.market_id = r2.market_id AND r1.rn = 1 AND r2.rn = 2\n    WHERE ABS(r1.last_trade_price - r2.last_trade_price) > 0.01\n)\nSELECT \n    m.market_id,\n    m.slug,\n    m.question,\n    pc.current_price,\n    pc.previous_price,\n    ROUND(pc.pct_change * 100, 2) as pct_change_percent,\n    mc.volume,\n    mc.liquidity,\n    'Breakout' as strategy,\n    CASE \n        WHEN ABS(pc.pct_change) > 1.0 THEN 'Massive price movement detected'\n        WHEN ABS(pc.pct_change) > 0.5 THEN 'Significant breakout'\n        ELSE 'Moderate price shift'\n    END as reasoning\nFROM price_changes pc\nJOIN markets m ON pc.market_id = m.market_id\nJOIN market_change mc ON m.change_id = mc.change_id\nWHERE LOWER(m.status) = 'active'\nAND ABS(pc.pct_change) > 0.10\nAND mc.volume > 100\nAND mc.liquidity > 500\nORDER BY ABS(pc.pct_change) DESC\nLIMIT 30\n'''\n\n# Strategy 2: Volume Shocks\nvolume_shocks_query = '''\nSELECT \n    m.market_id,\n    m.slug,\n    m.question,\n    mc.last_trade_price as current_price,\n    NULL as previous_price,\n    NULL as pct_change_percent,\n    mc.volume,\n    mc.liquidity,\n    'Volume Shock' as strategy,\n    CASE \n        WHEN mc.volume / NULLIF(mc.liquidity, 0) > 100 THEN 'Extreme volume-to-liquidity ratio'\n        WHEN mc.volume / NULLIF(mc.liquidity, 0) > 50 THEN 'High volume shock'\n        ELSE 'Elevated trading activity'\n    END as reasoning\nFROM markets m\nJOIN market_change mc ON m.change_id = mc.change_id\nWHERE LOWER(m.status) = 'active'\nAND mc.volume > 1000\nAND mc.liquidity > 500\nAND mc.liquidity < 10000\nORDER BY mc.volume / NULLIF(mc.liquidity, 0) DESC\nLIMIT 30\n'''\n\n# Strategy 3: Mid-Volume Active Markets\nactive_markets_query = '''\nSELECT \n    m.market_id,\n    m.slug,\n    m.question,\n    mc.last_trade_price as current_price,\n    NULL as previous_price,\n    NULL as pct_change_percent,\n    mc.volume,\n    mc.liquidity,\n    'Mid-Volume Active' as strategy,\n    CASE \n        WHEN mc.volume > 1000000 THEN 'Very high volume with solid liquidity'\n        WHEN mc.volume > 100000 THEN 'High trading activity'\n        ELSE 'Active market with good metrics'\n    END as reasoning\nFROM markets m\nJOIN market_change mc ON m.change_id = mc.change_id\nWHERE LOWER(m.status) = 'active'\nAND mc.volume > 1000\nAND mc.liquidity > 2000\nAND mc.liquidity < 20000\nORDER BY mc.volume DESC\nLIMIT 30\n'''\n\n# Execute queries\nbreakouts_df = pd.read_sql(breakouts_query, conn)\nvolume_shocks_df = pd.read_sql(volume_shocks_query, conn)\nactive_markets_df = pd.read_sql(active_markets_query, conn)\n\n# Combine all strategies\nall_markets = pd.concat([breakouts_df, volume_shocks_df, active_markets_df], ignore_index=True)\n\n# Remove duplicates by market_id\nall_markets = all_markets.drop_duplicates(subset=['market_id'])\n\n# Calculate interest score based on metrics\ndef calculate_interest_score(row):\n    score = 0\n    \n    # Price movement score\n    if pd.notna(row['pct_change_percent']):\n        pct_change = abs(row['pct_change_percent'])\n        if pct_change > 1000:\n            score += 50\n        elif pct_change > 100:\n            score += 30\n        elif pct_change > 10:\n            score += 20\n    \n    # Volume score\n    if pd.notna(row['volume']):\n        if row['volume'] > 1000000:\n            score += 40\n        elif row['volume'] > 100000:\n            score += 25\n        elif row['volume'] > 10000:\n            score += 15\n    \n    # Liquidity score (mid-volume preference)\n    if pd.notna(row['liquidity']):\n        if 500 <= row['liquidity'] <= 10000:\n            score += 20\n        elif row['liquidity'] > 10000:\n            score += 10\n    \n    # Strategy bonus\n    if row['strategy'] == 'Breakout':\n        score += 30\n    elif row['strategy'] == 'Volume Shock':\n        score += 25\n    elif row['strategy'] == 'Mid-Volume Active':\n        score += 15\n    \n    return score\n\nall_markets['interest_score'] = all_markets.apply(calculate_interest_score, axis=1)\n\n# Sort by interest score\nall_markets = all_markets.sort_values('interest_score', ascending=False).head(90)\n\nprint(f'Total markets identified: {len(all_markets)}')\nprint('\\\\nTop 10 markets by interest score:')\nprint(all_markets[['question', 'strategy', 'interest_score', 'current_price', 'volume', 'liquidity']].head(10).to_string())\n\n# Save to file\noutput_file = f'/home/boldplane/.openclaw/workspace/relevant_markets/{today}.txt'\nwith open(output_file, 'w') as f:\n    f.write(f'# Polymarket Quantitative Analysis Report - {today}\\\\n')\n    f.write(f'# Generated by The Quant Scout (Market Ranker)\\\\n')\n    f.write(f'# Total Markets Analyzed: {len(all_markets)}\\\\n')\n    f.write(f'# Analysis Date: {datetime.now().strftime(\\\"%Y-%m-%d %H:%M:%S UTC\\\")}\\\\n\\\\n')\n    \n    for idx, row in all_markets.iterrows():\n        f.write(f'## Market {idx+1}\\\\n')\n        f.write(f'Market ID: {row[\\\"market_id\\\"]}\\\\n')\n        f.write(f'Slug: {row[\\\"slug\\\"]}\\\\n')\n        f.write(f'Question: {row[\\\"question\\\"]}\\\\n')\n        f.write(f'Current Price: {row[\\\"current_price\\\"]}\\\\n')\n        if pd.notna(row[\\\"previous_price\\\"]):\n            f.write(f'Previous Price: {row[\\\"previous_price\\\"]}\\\\n')\n            f.write(f'Price Change: {row[\\\"pct_change_percent\\\"]}%\\\\n')\n        f.write(f'Volume: {row[\\\"volume\\\"]:.2f}\\\\n')\n        f.write(f'Liquidity: {row[\\\"liquidity\\\"]:.2f}\\\\n')\n        f.write(f'Strategy: {row[\\\"strategy\\\"]}\\\\n')\n        f.write(f'Interest Score: {row[\\\"interest_score\\\"]}\\\\n')\n        f.write(f'Reasoning: {row[\\\"reasoning\\\"]}\\\\n')\n        f.write('\\\\n')\n\nprint(f'\\\\nReport saved to: {output_file}')\nconn.close()\n\""}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":73,"output":1954,"cacheRead":54336,"cacheWrite":0,"totalTokens":56363,"cost":{"input":2.0440000000000003e-11,"output":8.2068e-10,"cacheRead":1.521408e-9,"cacheWrite":0,"total":2.362528e-9}},"stopReason":"toolUse","timestamp":1773618567441}}
