{"type":"message","id":"b9bf066a","parentId":"52c9e135","timestamp":"2026-03-20T14:28:56.170Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's still a bash escaping issue. Let me write it to a file first and then execute it. I'll create a proper Python script that handles all the steps cleanly without bash escaping issues.","thinkingSignature":"reasoning"},{"type":"text","text":"Let me create a proper Python script to handle everything:"},{"type":"toolCall","id":"call_c2608d644ca043d5abc25cd7","name":"write","arguments":{"path":"/home/boldplane/.openclaw/workspace/generate_final_rankings.py","content":"#!/usr/bin/env python3\n\"\"\"\nGenerate final rankings of 90 markets and create reports\n\"\"\"\n\nimport sqlite3\nimport pandas as pd\nfrom datetime import datetime\n\nprint('🏆 GENERATING FINAL RANKINGS OF 90 MARKETS')\nprint('=' * 80)\n\n# Connect to database\ndb_path = '/home/boldplane/.openclaw/skills/market-scarper/polymarket.db'\nconn = sqlite3.connect(db_path)\n\n# Get all active markets with data\nprint('📊 Fetching active markets from database...')\nquery = '''\nSELECT\n    m.market_id,\n    m.question,\n    mc.last_trade_price as current_price,\n    mc.volume,\n    mc.liquidity,\n    mc.spread\nFROM markets m\nJOIN market_change mc ON m.change_id = mc.change_id\nWHERE LOWER(m.status) = 'active'\nAND mc.last_trade_price IS NOT NULL\nAND mc.volume IS NOT NULL\nAND mc.liquidity IS NOT NULL\n'''\n\ndf = pd.read_sql(query, conn)\nprint(f'   Found {len(df)} active markets')\n\n# Quantitative scoring function\ndef calculate_score(row):\n    score = 0\n\n    # Volume (0-40 pts)\n    vol = row['volume']\n    if vol > 1000000: score += 40\n    elif vol > 500000: score += 30\n    elif vol > 100000: score += 25\n    elif vol > 50000: score += 20\n    elif vol > 10000: score += 15\n    elif vol > 1000: score += 10\n    elif vol > 100: score += 5\n\n    # Liquidity - Goldilocks (0-30 pts)\n    liq = row['liquidity']\n    if 2000 <= liq <= 100000: score += 30\n    elif 500 <= liq < 2000: score += 20\n    elif liq > 100000: score += 10\n    elif liq > 100: score += 5\n\n    # Price position (0-25 pts)\n    price = row['current_price']\n    if 0.10 <= price <= 0.90: score += 25\n    elif 0.05 <= price <= 0.95: score += 15\n    elif 0.02 <= price <= 0.98: score += 10\n    else: score += 5\n\n    # Spread (0-15 pts)\n    spread = row.get('spread', 1.0)\n    if spread < 0.05: score += 15\n    elif spread < 0.10: score += 10\n    elif spread < 0.20: score += 5\n\n    return score\n\n# Apply scoring\nprint('📈 Applying quantitative scoring...')\ndf['score'] = df.apply(calculate_score, axis=1)\n\n# Select top 90\nprint('🏆 Selecting top 90 markets...')\nranked_df = df.sort_values('score', ascending=False).head(90)\n\n# Ensure exactly 90\nif len(ranked_df) < 90:\n    additional = df[~df['market_id'].isin(ranked_df['market_id'])].head(90 - len(ranked_df))\n    ranked_df = pd.concat([ranked_df, additional])\n\nranked_df = ranked_df.head(90).reset_index(drop=True)\nprint(f'   ✅ Selected exactly {len(ranked_df)} markets')\n\n# Save raw IDs\nraw_ids_file = '/home/boldplane/.openclaw/workspace/relevant_markets/raw_ids.txt'\nwith open(raw_ids_file, 'w') as f:\n    for market_id in ranked_df['market_id']:\n        f.write(f'{market_id}\\n')\nprint(f'   ✅ Saved market IDs to: {raw_ids_file}')\n\n# Create intelligence report\ntoday = datetime.now().strftime('%Y-%m-%d')\nreport_file = f'/home/boldplane/.openclaw/workspace/relevant_markets/intelligence_report_{today}.txt'\n\nwith open(report_file, 'w') as f:\n    f.write(f'# POLYMARKET INTELLIGENCE REPORT - {today}\\n')\n    f.write(f'# Generated by The Quant Scout\\n')\n    f.write(f'# Total Markets: {len(ranked_df)}\\n\\n')\n\n    f.write('## EXECUTIVE SUMMARY\\n')\n    f.write(f'This report presents the {len(ranked_df)} most promising Polymarket opportunities ')\n    f.write('ranked by quantitative score. Markets were filtered from the active database using comprehensive metrics.\\n\\n')\n\n    f.write('### KEY METRICS\\n')\n    f.write(f'- **Average Price**: {ranked_df[\"current_price\"].mean():.3f}\\n')\n    f.write(f'- **Average Volume**: ${ranked_df[\"volume\"].mean():,.0f}\\n')\n    f.write(f'- **Average Liquidity**: ${ranked_df[\"liquidity\"].mean():,.0f}\\n')\n    f.write(f'- **Price Range**: {ranked_df[\"current_price\"].min():.3f} - {ranked_df[\"current_price\"].max():.3f}\\n\\n')\n\n    f.write('## TOP 10 MARKETS\\n')\n    f.write('Rank | Market ID | Question | Price | Volume | Liquidity | Score\\n')\n    f.write('--- | --- | --- | --- | --- | --- | ---\\n')\n\n    for idx, row in ranked_df.head(10).iterrows():\n        q_short = row['question'][:50] + '...' if len(row['question']) > 50 else row['question']\n        f.write(f'{idx+1} | {row[\"market_id\"][:15]}... | {q_short} | {row[\"current_price\"]:.3f} | ')\n        f.write(f'${row[\"volume\"]:,.0f} | ${row[\"liquidity\"]:,.0f} | {row[\"score\"]:.0f}\\n')\n\n    f.write('\\n## COMPLETE LIST (90 MARKETS)\\n')\n    f.write('Rank | Market ID | Question | Price | Volume | Liquidity | Score\\n')\n    f.write('--- | --- | --- | --- | --- | --- | ---\\n')\n\n    for idx, row in ranked_df.iterrows():\n        q_short = row['question'][:40] + '...' if len(row['question']) > 40 else row['question']\n        f.write(f'{idx+1} | {row[\"market_id\"][:12]}... | {q_short} | {row[\"current_price\"]:.3f} | ')\n        f.write(f'${row[\"volume\"]:,.0f} | ${row[\"liquidity\"]:,.0f} | {row[\"score\"]:.0f}\\n')\n\nprint(f'✅ Intelligence report saved: {report_file}')\n\n# Show top markets\nprint('\\n🏆 TOP 10 MARKETS BY SCORE:')\nprint('=' * 100)\nfor idx, row in ranked_df.head(10).iterrows():\n    print(f'{idx+1}. {row[\"question\"][:60]}...')\n    print(f'   Price: {row[\"current_price\"]:.3f} | Volume: ${row[\"volume\"]:,.0f} | Liquidity: ${row[\"liquidity\"]:,.0f} | Score: {row[\"score\"]:.0f}')\n    print()\n\nconn.close()\nprint('✅ Rankings complete!')\n\""}}],"api":"openai-completions","provider":"openrouter","model":"stepfun/step-3.5-flash:free","usage":{"input":114433,"output":1786,"cacheRead":0,"cacheWrite":0,"totalTokens":116219,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774016915657}}
