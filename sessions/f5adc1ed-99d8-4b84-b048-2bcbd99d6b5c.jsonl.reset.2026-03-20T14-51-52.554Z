{"type":"message","id":"64274d31","parentId":"7c29ba79","timestamp":"2026-03-20T14:18:54.259Z","message":{"role":"assistant","content":[{"type":"text","text":"I'll execute the complete pipeline: rank exactly 90 most promising markets, run the prediction engine, and create the comprehensive report."},{"type":"toolCall","id":"call_00_zC1A7YkZ9kMlCJM0tIajhLLH","name":"exec","arguments":{"command":"cd ~/.openclaw/skills/market-scarper && source venv/bin/activate && python3 -c \"\nimport sqlite3\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nimport json\n\nprint('🚀 Starting complete Polymarket analysis pipeline...')\nprint('=' * 80)\n\nconn = sqlite3.connect('polymarket.db')\n\n# Step 1: Get ALL active markets with basic metrics\nprint('📊 Step 1: Fetching all active markets...')\nall_markets_query = '''\nSELECT \n    m.market_id,\n    m.slug,\n    m.question,\n    m.market_category,\n    mc.last_trade_price as current_price,\n    mc.volume,\n    mc.liquidity,\n    mc.spread,\n    mc.datetime as last_update\nFROM markets m\nJOIN market_change mc ON m.change_id = mc.change_id\nWHERE LOWER(m.status) = 'active'\nAND mc.last_trade_price IS NOT NULL\nAND mc.volume IS NOT NULL\nAND mc.liquidity IS NOT NULL\n'''\n\nall_df = pd.read_sql(all_markets_query, conn)\nprint(f'   Found {len(all_df)} active markets with data')\n\n# Step 2: Apply quantitative scoring\nprint('📈 Step 2: Applying quantitative scoring...')\n\ndef calculate_quantitative_score(row):\n    score = 0\n    \n    # Volume score (0-40 points)\n    volume = row['volume']\n    if volume > 1000000:\n        score += 40\n    elif volume > 500000:\n        score += 30\n    elif volume > 100000:\n        score += 25\n    elif volume > 50000:\n        score += 20\n    elif volume > 10000:\n        score += 15\n    elif volume > 1000:\n        score += 10\n    elif volume > 100:\n        score += 5\n    \n    # Liquidity score - Goldilocks zone (0-30 points)\n    liquidity = row['liquidity']\n    if 2000 <= liquidity <= 100000:  # Perfect mid-volume\n        score += 30\n    elif 500 <= liquidity < 2000:    # Lower but acceptable\n        score += 20\n    elif liquidity > 100000:         # Too high, institutional\n        score += 10\n    elif liquidity > 100:            # Very low\n        score += 5\n    \n    # Price position score - avoid extremes (0-25 points)\n    price = row['current_price']\n    if 0.10 <= price <= 0.90:        # Ideal trading range\n        score += 25\n    elif 0.05 <= price <= 0.95:      # Good range\n        score += 15\n    elif 0.02 <= price <= 0.98:      # Acceptable\n        score += 10\n    else:                            # Near certainty\n        score += 5\n    \n    # Spread score - tighter is better (0-15 points)\n    spread = row.get('spread', 1.0)\n    if spread < 0.05:\n        score += 15\n    elif spread < 0.10:\n        score += 10\n    elif spread < 0.20:\n        score += 5\n    \n    # Category bonus (0-10 points)\n    category = str(row.get('market_category', '')).lower()\n    volatile_categories = ['politics', 'crypto', 'sports', 'election', 'trump', 'ukraine', 'fed', 'rate']\n    if any(vc in category for vc in volatile_categories):\n        score += 10\n    \n    return score\n\nall_df['quant_score'] = all_df.apply(calculate_quantitative_score, axis=1)\n\n# Step 3: Apply Alpha Playbook strategies\nprint('🎯 Step 3: Applying Alpha Playbook strategies...')\n\ndef apply_alpha_strategies(row, history_df):\n    strategies = []\n    score_boost = 0\n    \n    market_id = row['market_id']\n    price = row['current_price']\n    volume = row['volume']\n    liquidity = row['liquidity']\n    \n    # Get market history\n    market_history = history_df[history_df['market_id'] == market_id]\n    \n    # Strategy 1: Volume Shock\n    if len(market_history) >= 3:\n        recent_volume = market_history['volume'].iloc[-1]\n        avg_volume = market_history['volume'].iloc[-3:].mean()\n        if recent_volume > avg_volume * 3 and volume > 1000:\n            strategies.append('Volume Shock')\n            score_boost += 25\n    \n    # Strategy 2: Breakout (need price history)\n    if len(market_history) >= 2:\n        recent_price = market_history['last_trade_price'].iloc[-1]\n        prev_price = market_history['last_trade_price'].iloc[-2]\n        if abs(recent_price - prev_price) > 0.10:\n            strategies.append('Breakout')\n            score_boost += 30\n    \n    # Strategy 3: Ghost Awakens\n    if liquidity < 2000 and volume > 100:\n        strategies.append('Ghost Awakens')\n        score_boost += 40\n    \n    # Strategy 4: Mid-Volume Mandate\n    if 2000 <= liquidity <= 100000:\n        strategies.append('Mid-Volume')\n        score_boost += 20\n    \n    # Strategy 5: Information Drift (simplified)\n    if len(market_history) >= 5:\n        prices = market_history['last_trade_price'].iloc[-5:]\n        if all(prices.diff().dropna() > 0) or all(prices.diff().dropna() < 0):\n            strategies.append('Information Drift')\n            score_boost += 25\n    \n    # Strategy 6: Risk-Free Arbitrage (simplified check)\n    if price < 0.02 or price > 0.98:\n        strategies.append('Dead Money')\n        score_boost -= 50  # Penalty for extreme prices\n    \n    return ', '.join(strategies) if strategies else 'Mid-Volume Active', score_boost\n\n# Get recent history for all markets\nprint('   Fetching market history for strategy analysis...')\nhistory_query = '''\nSELECT market_id, last_trade_price, volume, datetime\nFROM market_change\nWHERE datetime >= datetime('now', '-3 days')\nORDER BY market_id, datetime\n'''\nhistory_df = pd.read_sql(history_query, conn)\n\n# Apply strategies\nall_df[['strategy', 'strategy_boost']] = all_df.apply(\n    lambda x: pd.Series(apply_alpha_strategies(x, history_df)), axis=1\n)\n\n# Calculate total score\nall_df['total_score'] = all_df['quant_score'] + all_df['strategy_boost']\n\n# Step 4: Rank and select exactly 90 markets\nprint('🏆 Step 4: Ranking and selecting exactly 90 markets...')\nranked_df = all_df.sort_values('total_score', ascending=False).head(90)\n\n# Ensure we have exactly 90\nif len(ranked_df) < 90:\n    print(f'   Warning: Only {len(ranked_df)} markets meet criteria')\n    # Add more markets if needed\n    additional_needed = 90 - len(ranked_df)\n    additional_df = all_df[~all_df['market_id'].isin(ranked_df['market_id'])].head(additional_needed)\n    ranked_df = pd.concat([ranked_df, additional_df])\nelif len(ranked_df) > 90:\n    ranked_df = ranked_df.head(90)\n\nprint(f'   ✅ Selected exactly {len(ranked_df)} markets')\n\n# Step 5: Create intelligence report\nprint('📋 Step 5: Creating intelligence report...')\ntoday = datetime.now().strftime('%Y-%m-%d')\nreport_file = f'/home/boldplane/.openclaw/workspace/relevant_markets/intelligence_report_{today}.txt'\n\nwith open(report_file, 'w') as f:\n    f.write(f'# POLYMARKET INTELLIGENCE REPORT - {today}\\\\n')\n    f.write(f'# Generated by The Quant Scout\\\\n')\n    f.write(f'# Analysis Date: {datetime.now().strftime(\\\"%Y-%m-%d %H:%M:%S UTC\\\")}\\\\n')\n    f.write(f'# Total Markets Analyzed: {len(all_df)}\\\\n')\n    f.write(f'# Top Markets Selected: {len(ranked_df)}\\\\n\\\\n')\n    \n    f.write('## EXECUTIVE SUMMARY\\\\n')\n    f.write('This report identifies the 90 most promising Polymarket opportunities based on quantitative metrics ')\n    f.write('and the Alpha Playbook strategies. Markets are ranked by total score (quantitative + strategy boost).\\\\n\\\\n')\n    \n    # Summary statistics\n    avg_price = ranked_df['current_price'].mean()\n    avg_volume = ranked_df['volume'].mean()\n    avg_liquidity = ranked_df['liquidity'].mean()\n    \n    f.write('### KEY METRICS\\\\n')\n    f.write(f'- **Average Price**: {avg_price:.3f}\\\\n')\n    f.write(f'- **Average Volume**: ${avg_volume:,.0f}\\\\n')\n    f.write(f'- **Average Liquidity**: ${avg_liquidity:,.0f}\\\\n')\n    f.write(f'- **Price Range**: {ranked_df[\\\"current_price\\\"].min():.3f} - {ranked_df[\\\"current_price\\\"].max():.3f}\\\\n\\\\n')\n    \n    # Strategy distribution\n    f.write('### STRATEGY DISTRIBUTION\\\\n')\n    strategy_counts = ranked_df['strategy'].value_counts()\n    for strategy, count in strategy_counts.items():\n        f.write(f'- **{strategy}**: {count} markets\\\\n')\n    f.write('\\\\n')\n    \n    f.write('## TOP 10 MARKETS\\\\n')\n    f.write('Rank | Market ID | Question | Price | Volume | Liquidity | Strategy | Total Score\\\\n')\n    f.write('--- | --- | --- | --- | --- | --- | --- | ---\\\\n')\n    \n    for idx, row in ranked_df.head(10).iterrows():\n        market_id_short = row['market_id'][:20] + '...' if len(row['market_id']) > 20 else row['market_id']\n        question_short = row['question'][:50] + '...' if len(row['question']) > 50 else row['question']\n        f.write(f'{idx+1} | {market_id_short} | {question_short} | {row[\\\"current_price\\\"]:.3f} | ')\n        f.write(f'${row[\\\"volume\\\"]:,.0f} | ${row[\\\"liquidity\\\"]:,.0f} | {row[\\\"strategy\\\"]} | {row[\\\"total_score\\\"]:.0f}\\\\n')\n    \n    f.write('\\\\n## COMPLETE MARKET LIST (90 MARKETS)\\\\n')\n    f.write('Rank | Market ID | Question | Price | Volume | Liquidity | Strategy | Quant Score | Strategy Boost | Total Score\\\\n')\n    f.write('--- | --- | --- | --- | --- | --- | --- | --- | --- | ---\\\\n')\n    \n    for idx, row in ranked_df.iterrows():\n        market_id_short = row['market_id'][:15] + '...' if len(row['market_id']) > 15 else row['market_id']\n        question_short = row['question'][:40] + '...' if len(row['question']) > 40 else row['question']\n        f.write(f'{idx+1} | {market_id_short} | {question_short} | {row[\\\"current_price\\\"]:.3f} | ')\n        f.write(f'${row[\\\"volume\\\"]:,.0f} | ${row[\\\"liquidity\\\"]:,.0f} | {row[\\\"strategy\\\"]} | ')\n        f.write(f'{row[\\\"quant_score\\\"]:.0f} | {row[\\\"strategy_boost\\\"]:.0f} | {row[\\\"total_score\\\"]:.0f}\\\\n')\n    \n    f.write('\\\\n## RECOMMENDED ACTIONS\\\\n')\n    f.write('1. **Review Top 10 Markets**: Highest scoring opportunities\\\\n')\n    f.write('2. **Check Strategy Alignment**: Focus on markets matching your preferred strategies\\\\n')\n    f.write('3. **Verify Liquidity**: Ensure sufficient liquidity for your position size\\\\n')\n    f.write('4. **Monitor Price Levels**: Avoid extreme prices (<0.02 or >0.98)\\\\n')\n    f.write('5. **Run Prediction Engine**: For detailed probability analysis\\\\n')\n\nprint(f'   ✅ Intelligence report saved to: {report_file}')\n\n# Step 6: Save market IDs for prediction engine\nprint('🔧 Step 6: Preparing for prediction engine...')\nraw_ids_file = '/home/boldplane/.openclaw/workspace/relevant_markets/raw_ids.txt'\nwith open(raw_ids_file, 'w') as f:\n    for market_id in ranked_df['market_id']:\n        f.write(f'{market_id}\\\\n')\n\nprint(f'   ✅ Saved {len(ranked_df)} market IDs to: {raw_ids_file}')\n\n# Step 7: Show top markets\nprint('\\\\n🏆 TOP 5 MARKETS BY TOTAL SCORE:')\nprint('=' * 100)\nfor idx, row in ranked_df.head(5).iterrows():\n    print(f'{idx+1}. {row[\\\"question\\\"][:60]}...')\n    print(f'   Price: {row[\\\"current_price\\\"]:.3f} | Volume: ${row[\\\"volume\\\"]:,.0f} | Liquidity: ${row[\\\"liquidity\\\"]:,.0f}')\n    print(f'   Strategy: {row[\\\"strategy\\\"]} | Score: {row[\\\"total_score\\\"]:.0f} (Quant: {row[\\\"quant_score\\\"]:.0f} + Strategy: {row[\\\"strategy_boost\\\"]:.0f})')\n    print()\n\nconn.close()\nprint('✅ Pipeline complete! Ready to run prediction engine.')\n\""}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":79166,"output":3187,"cacheRead":3712,"cacheWrite":0,"totalTokens":86065,"cost":{"input":2.2166480000000002e-8,"output":1.33854e-9,"cacheRead":1.03936e-10,"cacheWrite":0,"total":2.3608956000000002e-8}},"stopReason":"toolUse","timestamp":1774016221189}}
